<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/admin_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/admin_panel">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:includeFontPadding="false"
            android:text="@string/global_settings"
            android:textColor="@color/admin_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCloseSettings"
            android:layout_width="64dp"
            android:layout_height="34dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:background="@drawable/button_secondary_bg"
            android:text="@string/done"
            android:textAllCaps="false"
            android:textColor="@color/admin_primary"
            android:textSize="14sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/settings_row_bg"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/appearance_mode"
                    android:textColor="@color/admin_text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <RadioGroup
                    android:id="@+id/radioAppearanceMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioLightMode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="34dp"
                        android:layout_weight="1"
                        android:text="@string/light_mode"
                        android:textColor="@color/admin_text"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/radioDarkMode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="34dp"
                        android:layout_weight="1"
                        android:text="@string/dark_mode"
                        android:textColor="@color/admin_text"
                        android:textSize="14sp" />

                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/settings_row_bg"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/font_size_mode"
                    android:textColor="@color/admin_text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <RadioGroup
                    android:id="@+id/radioFontSizeMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioStandardText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="34dp"
                        android:layout_weight="1"
                        android:text="@string/standard_text_mode"
                        android:textColor="@color/admin_text"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/radioLargeText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="34dp"
                        android:layout_weight="1"
                        android:text="@string/large_text_mode"
                        android:textColor="@color/admin_text"
                        android:textSize="14sp" />

                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowGuideContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="46dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/settings_row_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:text="@string/guide_content"
                    android:textColor="@color/admin_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text=">"
                    android:textColor="@color/admin_text_muted"
                    android:textSize="18sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/settings_row_bg"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp"
                android:layout_marginBottom="8dp">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchEasyMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:text="@string/easy_mode"
                    android:textColor="@color/admin_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/easy_mode_hint"
                    android:textColor="@color/admin_text_muted"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutEasyModeOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/settings_row_bg"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchEasyModeSwipeHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:text="@string/easy_mode_show_swipe_hint"
                    android:textColor="@color/admin_text"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/easy_mode_show_swipe_hint_desc"
                    android:textColor="@color/admin_text_muted"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowPreferredSim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="46dp"
                android:orientation="vertical"
                android:background="@drawable/settings_row_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:includeFontPadding="false"
                        android:text="@string/preferred_sim"
                        android:textColor="@color/admin_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPreferredSimValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/preferred_sim_none"
                        android:textColor="@color/admin_text_muted"
                        android:textSize="14sp"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text=">"
                        android:textColor="@color/admin_text_muted"
                        android:textSize="18sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/preferred_sim_desc"
                    android:textColor="@color/admin_text_muted"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/settings_row_bg"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp"
                android:layout_marginBottom="8dp">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoRecovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:text="@string/auto_recovery"
                    android:textColor="@color/admin_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:checked="true" />

                <LinearLayout
                    android:id="@+id/layoutAutoRecoveryOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTimeoutLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/timeout_seconds"
                        android:textColor="@color/admin_text_muted"
                        android:textSize="12sp"
                        android:layout_marginBottom="5dp" />

                    <EditText
                        android:id="@+id/etTimeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="42dp"
                        android:inputType="number"
                        android:text="10"
                        android:textColor="@color/admin_text"
                        android:textColorHint="@color/admin_text_muted"
                        android:background="@drawable/admin_input_bg"
                        android:textSize="15sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:singleLine="true" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowContactManagement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="46dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/settings_row_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:text="@string/contact_management"
                    android:textColor="@color/admin_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text=">"
                    android:textColor="@color/admin_text_muted"
                    android:textSize="18sp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
