<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFE0E5" />
            <stroke android:width="1dp" android:color="@color/danger" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/admin_danger_bg" />
            <stroke android:width="1dp" android:color="#F2B5BF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
